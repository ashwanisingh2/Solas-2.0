<UserControl xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             x:Class="Modules.DriverManagement.Views.DriverBackup.DriverBackupView">
    <Grid Margin="12">
        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
            <Button Content="Backup All" Command="{Binding BackupAllCommand}" Width="120" />
            <Button Content="Refresh History" Command="{Binding RefreshHistoryCommand}" Width="120" Margin="8,0,0,0" />
        </StackPanel>

        <DataGrid ItemsSource="{Binding History}" AutoGenerateColumns="False" IsReadOnly="True">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Date" Binding="{Binding BackupDate}" Width="150" />
                <DataGridTextColumn Header="Path" Binding="{Binding BackupPath}" Width="*" />
                <DataGridTextColumn Header="Type" Binding="{Binding BackupType}" Width="100" />
                <DataGridTextColumn Header="Success" Binding="{Binding Success}" Width="80" />
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>