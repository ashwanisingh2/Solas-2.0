<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="Modules.DriverManagement.Views.MainWindow"
        Title="Driver Management" Height="800" Width="1200">
    <DockPanel>
        <StackPanel DockPanel.Dock="Left" Width="220" Background="#222" VerticalAlignment="Stretch">
            <Button Content="Dashboard" Name="BtnDashboard" Margin="8" />
            <Button Content="Scanner" Name="BtnScanner" Margin="8" />
            <Button Content="Health" Name="BtnHealth" Margin="8" />
            <Button Content="Backup" Name="BtnBackup" Margin="8" />
            <Button Content="Restore" Name="BtnRestore" Margin="8" />
            <Button Content="Reports" Name="BtnReports" Margin="8" />
            <Button Content="Diagnostics" Name="BtnDiagnostics" Margin="8" />
            <Button Content="Settings" Name="BtnSettings" Margin="8" />
        </StackPanel>

        <ContentControl Name="MainHost" />
    </DockPanel>
</Window>